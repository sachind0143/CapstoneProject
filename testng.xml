<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="FlightBookingSuite" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="com.flightbooking.automation.listeners.TestListener"/>
    </listeners>

    <test name="FlightBookingTest">

        <classes>
            <class name="com.flightbooking.automation.tests.FlightBookingPositiveTest"/>
        </classes>

    </test>
    <test name="FlightBookingNegativeTest">
    	<classes>
    		<class name="com.flightbooking.automation.tests.FlightBookingNegativeTest">
    			</class>
    	</classes>
    </test>

</suite>
